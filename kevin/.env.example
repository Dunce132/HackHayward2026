PERPLEXITY_API_KEY=your_perplexity_api_key
GOOGLE_PLACES_API_KEY=your_google_places_api_key
PORT=8080
# Lower = show restaurant carousel sooner (15–90, default 38)
RECOMMENDATION_THRESHOLD=38

# --- Firebase (Firestore + Google Sign-In) — optional; omit to run without accounts ---
# Download a service account JSON from Firebase Console → Project settings → Service accounts
# Then either set the path:
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json
# Or inline JSON (single line) — careful with quotes in deployment:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Web / client config (Firebase Console → Project settings → Your apps → Web)
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_APP_ID=1:xxx:web:xxx
FIREBASE_MESSAGING_SENDER_ID=123456789
